{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/upload", "dest": "/api/index.py" },
    { "src": "/files", "dest": "/api/index.py" },
    { "src": "/analyze", "dest": "/api/index.py" },
    { "src": "/chart/(.*)", "dest": "/api/index.py" },
    { "src": "/export/(.*)", "dest": "/api/index.py" },
    { "src": "/columns/(.*)", "dest": "/api/index.py" },
    { "src": "/sessions", "dest": "/api/index.py" },
    { "src": "/sessions/(.*)", "dest": "/api/index.py" },
    { "src": "/docs", "dest": "/api/index.py" },
    { "src": "/openapi.json", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
