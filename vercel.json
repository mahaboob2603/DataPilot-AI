{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api/index.py" },
    { "source": "/upload", "destination": "/api/index.py" },
    { "source": "/files", "destination": "/api/index.py" },
    { "source": "/analyze", "destination": "/api/index.py" },
    { "source": "/chart/:path*", "destination": "/api/index.py" },
    { "source": "/export/:path*", "destination": "/api/index.py" },
    { "source": "/columns/:path*", "destination": "/api/index.py" },
    { "source": "/sessions/:path*", "destination": "/api/index.py" },
    { "source": "/sessions", "destination": "/api/index.py" },
    { "source": "/docs", "destination": "/api/index.py" },
    { "source": "/openapi.json", "destination": "/api/index.py" }
  ]
}
